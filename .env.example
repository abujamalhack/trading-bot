# ===== الشبكة =====
# اختر الشبكة: base, arbitrum, polygon
NETWORK=base

# عناوين WETH/WNative (Base: 0x4200000000000000000000000000000000000006, Arbitrum: 0x82aF49447D8a07e3bd95BD0d56f35241523fBab1, Polygon: 0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270)
WNATIVE_ADDRESS=0x4200000000000000000000000000000000000006

# عنوان Factory (Uniswap V2)
FACTORY_ADDRESS=0x8909Dc15e40173Ff4699343b6eB8132c65e18eC6

# عنوان Router
ROUTER_ADDRESS=0x4752ba5DBc23f44D87826276BF6Fd6b1C372aD24

# رابط RPC WebSocket سريع (مدفوع يوصى به)
RPC_WS_URL=wss://base-mainnet.g.alchemy.com/v2/your-api-key

# رابط RPC HTTP للاستعلامات العادية (اختياري، يستخدم كاحتياطي)
RPC_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/your-api-key

# معرف الشبكة
CHAIN_ID=8453

# ===== المحفظة =====
PRIVATE_KEY=your_private_key_here_without_0x
# (اختياري) عنوان المحفظة سيتم اشتقاقه من المفتاح إن لم يُعط
WALLET_ADDRESS=

# ===== إعدادات التداول =====
# الحد الأدنى للسيولة بالدولار (USD)
MIN_LIQUIDITY_USD=5000

# النسبة القصوى للانزلاق السعري (20% = 20)
MAX_SLIPPAGE_PERCENT=20

# مضاعف سعر الغاز (مثلاً 1.2 يعني 20% أعلى من السعر الحالي)
GAS_PRICE_MULTIPLIER=1.2

# حد الغاز للشراء
GAS_LIMIT=500000

# مبلغ الشراء بالعملة الأصلية (ETH على Base/Arbitrum، MATIC على Polygon)
BUY_AMOUNT_NATIVE=0.01

# الحد الأقصى لضريبة البيع المسموح بها (%)
MAX_SELL_TAX=10

# الحد الأقصى لضريبة الشراء المسموح بها (%)
MAX_BUY_TAX=10

# تفعيل فحص Honeypot عبر GoPlus
CHECK_HONEYPOT=true

# ===== إدارة المخاطر =====
# نسبة رأس المال لكل صفقة (2% = 0.02) - يستخدم لحساب الحد الأقصى للشراء
RISK_PER_TRADE=0.02

# الحد الأقصى لعدد الصفقات المتزامنة
MAX_CONCURRENT_POSITIONS=3

# الحد الأقصى لعدد الصفقات في الساعة
MAX_TRADES_PER_HOUR=5

# عدد الخسائر المتتالية المسموح بها قبل إيقاف البوت
MAX_CONSECUTIVE_LOSSES=3

# حد الخسارة اليومي (بالنسبة المئوية من الرصيد، مثلاً 5% = 5)
DAILY_LOSS_LIMIT_PERCENT=5

# ===== استراتيجية الخروج =====
# ربح جزئي 1: 25% (0.25)
TAKE_PROFIT_1=0.25
# نسبة البيع عند الربح الأول (30% من الكمية)
TAKE_PROFIT_1_PERCENT=30

# ربح جزئي 2: 50% (0.5)
TAKE_PROFIT_2=0.5
# نسبة البيع عند الربح الثاني (30% من الكمية)
TAKE_PROFIT_2_PERCENT=30

# الربح المتبقي يستخدم trailing stop
TRAILING_STOP_ACTIVATION=0.3   # بعد 30% ربح، يبدأ التفعيل
TRAILING_STOP_DISTANCE=0.1     # 10% تراجع من أعلى سعر

# وقف الخسارة الثابت (15% = 0.15)
STOP_LOSS_PERCENT=0.15

# ===== Oracle =====
# عنوان Oracle الخاص بـ ETH/USD على الشبكة (Chainlink)
# Base: 0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70
# Arbitrum: 0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612
# Polygon: 0xAB594600376Ec9fD91F8e885dADF0CE036862dE0
CHAINLINK_ETH_USD_ADDRESS=0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70

# ===== GoPlus API =====
GOPLUS_API_KEY=your_goplus_api_key_optional

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ===== Paper Trading =====
PAPER_TRADING=false   # true للمحاكاة بدون أموال حقيقية

# ===== قاعدة البيانات =====
DB_PATH=./data/trades.db

# ===== تسجيل العمليات =====
LOG_LEVEL=info
