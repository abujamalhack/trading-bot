    "ethers": "^6.10.0",
    "node-telegram-bot-api": "^0.64.0",
    "pino": "^8.17.1",
    "pino-pretty": "^10.3.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
